# ============================================================
# Glomix Landing Page — Biến môi trường
# Sao chép file này thành .env và điền giá trị thực tế
# KHÔNG commit file .env vào source control
# ============================================================

# Database (MySQL)
# Định dạng: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="mysql://user:password@localhost:3306/glomix_db"

# Admin Auth — JWT
# JWT_SECRET phải có ít nhất 32 ký tự ngẫu nhiên
JWT_SECRET="your-super-secret-key-min-32-characters-here"
# Thời gian hết hạn token: 24h, 7d, 30d, ...
JWT_EXPIRES_IN="24h"

# Google Analytics 4
# Lấy từ Google Analytics > Admin > Data Streams > Measurement ID
# Để trống nếu không dùng GA4
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# URL ứng dụng (dùng cho CORS và OG tags)
NEXT_PUBLIC_APP_URL="https://glomix.cloud"
